using Interoptopus.API;

namespace My.Company;

public partial class NestedA : IDisposable
{
    [StructLayout(LayoutKind.Sequential)]
    public struct Unmanaged
    {
        internal IntPtr _handle;

        [MethodImpl(MethodImplOptions.AggressiveOptimization)]
        public NestedA IntoManaged()
        {
            var h = GCHandle.FromIntPtr(_handle);
            var obj = (NestedA)h.Target!;
            h.Free();
            return obj;
        }

        [MethodImpl(MethodImplOptions.AggressiveOptimization)]
        public NestedA AsManaged()
        {
            return (NestedA)GCHandle.FromIntPtr(_handle).Target!;
        }
    }

    [MethodImpl(MethodImplOptions.AggressiveOptimization)]
    public Unmanaged IntoUnmanaged()
    {
        var h = GCHandle.Alloc(this);
        return new Unmanaged { _handle = GCHandle.ToIntPtr(h) };
    }

    [MethodImpl(MethodImplOptions.AggressiveOptimization)]
    public Unmanaged AsUnmanaged()
    {
        var h = GCHandle.Alloc(this);
        return new Unmanaged { _handle = GCHandle.ToIntPtr(h) };
    }

    public void Dispose() { }
}


public interface IPlugin
{
    static abstract ResultNestedAUint CreateA(uint value);
    static abstract ResultUintUint GetValue();
}

public interface INestedA<TSelf> where TSelf : INestedA<TSelf>
{
    static abstract TSelf NestedaCreate(uint value);
    ResultUintUint NestedaGetValue();
}
