public interface IPlugin
{
    static abstract NestedA CreateA(uint value);
    static abstract Task<NestedA> CreateAAsync(uint value);
    static abstract uint GetValue();
    static abstract Task<uint> GetValueAsync();
}

public interface INestedA<TSelf> where TSelf : INestedA<TSelf>
{
    static abstract TSelf Create(uint value);
    static abstract Task<TSelf> CreateAsync(uint value);
    uint GetValue();
    Task<uint> GetValueAsync();
}
