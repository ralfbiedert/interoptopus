/// Stores runtime trampolines registered by the Rust host at plugin load time.
public static unsafe class Trampoline
{
    private static delegate* unmanaged[Cdecl]<int, int*, int*, IntPtr> _wire_create;
    private static delegate* unmanaged[Cdecl]<IntPtr, int, int, void> _wire_destroy;
    private static delegate* unmanaged[Cdecl]<nint, byte*, int, void> _uncaught_exception;
    private static nint _uncaught_exception_ctx;

    private const long WIRE_CREATE              = 0x4952_4F50_5743_0001;
    private const long WIRE_DESTROY             = 0x4952_4F50_5743_0002;
    private const long UNCAUGHT_EXCEPTION       = 0x4952_4F50_5743_0003;
    private const long UNCAUGHT_EXCEPTION_CTX   = 0x4952_4F50_5743_0004;
    private const long QUERY_API_GUARD_HASH     = 0x4952_4F50_5143_0001;

    public static void Register(long id, IntPtr fn_ptr)
    {
        if (id == WIRE_CREATE)            _wire_create            = (delegate* unmanaged[Cdecl]<int, int*, int*, IntPtr>)fn_ptr;
        if (id == WIRE_DESTROY)           _wire_destroy           = (delegate* unmanaged[Cdecl]<IntPtr, int, int, void>)fn_ptr;
        if (id == UNCAUGHT_EXCEPTION)     _uncaught_exception     = (delegate* unmanaged[Cdecl]<nint, byte*, int, void>)fn_ptr;
        if (id == UNCAUGHT_EXCEPTION_CTX) _uncaught_exception_ctx = fn_ptr;
    }

    public static long QueryU64(long id)
    {
        if (id == QUERY_API_GUARD_HASH) return unchecked((long)0xC1B2FDCB2084DC1F);
        return 0;
    }

    public static IntPtr WireCreate(int size, out int len, out int capacity)
    {
        fixed (int* pLen = &len, pCap = &capacity)
        {
            return _wire_create(size, pLen, pCap);
        }
    }

    public static void WireDestroy(IntPtr data, int len, int capacity)
    {
        _wire_destroy(data, len, capacity);
    }

    /// Notifies the Rust host that an unhandled exception escaped a trampoline method.
    /// Safe to call even if no handler has been registered.
    public static void UncaughtException(string message)
    {
        if (_uncaught_exception == null) return;
        var bytes = System.Text.Encoding.UTF8.GetBytes(message);
        fixed (byte* ptr = bytes)
        {
            _uncaught_exception(_uncaught_exception_ctx, ptr, bytes.Length);
        }
    }
}

public static class Interop
{

    [UnmanagedCallersOnly(EntryPoint = "_trampoline_register")]
    internal static void _trampoline_register(long id, IntPtr fn_ptr) => Trampoline.Register(id, fn_ptr);


    [UnmanagedCallersOnly(EntryPoint = "_trampoline_query_u64")]
    internal static long _trampoline_query_u64(long id) => Trampoline.QueryU64(id);


    [UnmanagedCallersOnly(EntryPoint = "panic")]
    internal static void panic()
    {
        try
        {
            Plugin.Panic();
        }
        catch (Exception e)
        {
            Trampoline.UncaughtException(e.ToString());
        }
    }


    [UnmanagedCallersOnly(EntryPoint = "panic_async")]
    internal static unsafe TaskHandle panic_async(AsyncCallbackCommonNative cb)
    {
        var cts = new CancellationTokenSource();
        try
        {
            _ = Plugin.PanicAsync(cts.Token).ContinueWith(t => { if (t.IsCanceled || t.IsFaulted) cb.UnsafeCompleteCancelled(); else cb.UnsafeComplete(); });
        }
        catch (Exception e)
        {
            Trampoline.UncaughtException(e.ToString());
        }
        return TaskHandle.FromCancellationTokenSource(cts);
    }


    [UnmanagedCallersOnly(EntryPoint = "panic_async_with_result")]
    internal static unsafe TaskHandle panic_async_with_result(AsyncCallbackCommonNative cb)
    {
        var cts = new CancellationTokenSource();
        try
        {
            _ = ResultVoidError.FromCallResultAsync(() => Plugin.PanicAsyncWithResult(cts.Token)).ContinueWith(t => { if (t.IsCanceled) cb.UnsafeCompleteCancelled(); else cb.UnsafeComplete(t.Result.ToUnmanaged()); });
        }
        catch (Exception e)
        {
            Trampoline.UncaughtException(e.ToString());
        }
        return TaskHandle.FromCancellationTokenSource(cts);
    }


    [UnmanagedCallersOnly(EntryPoint = "panic_async_with_rval")]
    internal static unsafe TaskHandle panic_async_with_rval(AsyncCallbackCommonNative cb)
    {
        var cts = new CancellationTokenSource();
        try
        {
            _ = Plugin.PanicAsyncWithRval(cts.Token).ContinueWith(t => { if (t.IsCanceled || t.IsFaulted) cb.UnsafeCompleteCancelled(); else cb.UnsafeComplete(t.Result); });
        }
        catch (Exception e)
        {
            Trampoline.UncaughtException(e.ToString());
        }
        return TaskHandle.FromCancellationTokenSource(cts);
    }


    [UnmanagedCallersOnly(EntryPoint = "panic_with_result")]
    internal static ResultVoidError.Unmanaged panic_with_result()
    {
        try
        {
            return ResultVoidError.FromCallResult(() => Plugin.PanicWithResult()).ToUnmanaged();
        }
        catch (Exception e)
        {
            Trampoline.UncaughtException(e.ToString());
            return default;
        }
    }


    [UnmanagedCallersOnly(EntryPoint = "panic_with_rval")]
    internal static uint panic_with_rval()
    {
